  "conditions": {
    "blinded": {
      "name": "Cegado",
      "desc": "Una criatura cegada no puede ver y falla automáticamente cualquier prueba de característica que requiera la vista. Las tiradas de ataque contra la criatura tienen ventaja, y las tiradas de ataque de la criatura tienen desventaja."
    },
    "charmed": {
      "name": "Encantado",
      "desc": "Una criatura encantada no puede atacar a quien la encantó ni convertirlo en objetivo de habilidades o efectos mágicos dañinos. Quien la encantó tiene ventaja en las pruebas de característica para interactuar socialmente con la criatura."
    },
    "deafened": {
      "name": "Ensordecido",
      "desc": "Una criatura ensordecida no puede oír y falla automáticamente cualquier prueba de característica que requiera el oído."
    },
    "exhaustion": {
      "name": "Agotamiento",
      "desc": "El agotamiento se mide en seis niveles acumulativos: 1) desventaja en pruebas de característica; 2) velocidad reducida a la mitad; 3) desventaja en tiradas de ataque y salvación; 4) puntos de golpe máximos reducidos a la mitad; 5) velocidad reducida a 0; 6) muerte. Un descanso largo con comida y bebida reduce el nivel en 1."
    },
    "frightened": {
      "name": "Asustado",
      "desc": "Una criatura asustada tiene desventaja en las pruebas de característica y en las tiradas de ataque mientras la fuente de su miedo esté en su línea de visión. La criatura no puede acercarse voluntariamente a la fuente de su miedo."
    },
    "grappled": {
      "name": "Agarrado",
      "desc": "La velocidad de una criatura agarrada pasa a ser 0 y no puede beneficiarse de ningún bonificador a la velocidad. El estado termina si quien agarra queda incapacitado, o si un efecto saca a la criatura agarrada del alcance de quien la agarra."
    },
    "incapacitated": {
      "name": "Incapacitado",
      "desc": "Una criatura incapacitada no puede realizar acciones ni reacciones."
    },
    "invisible": {
      "name": "Invisible",
      "desc": "Una criatura invisible no puede verse sin ayuda de magia o de un sentido especial. A efectos de esconderse, la criatura está muy oscurecida. Su posición puede detectarse por el ruido que hace o los rastros que deja. Las tiradas de ataque contra la criatura tienen desventaja, y las tiradas de ataque de la criatura tienen ventaja."
    },
    "paralyzed": {
      "name": "Paralizado",
      "desc": "Una criatura paralizada está incapacitada y no puede moverse ni hablar. Falla automáticamente las tiradas de salvación de Fuerza y Destreza. Las tiradas de ataque contra la criatura tienen ventaja. Cualquier ataque que impacte a la criatura es un golpe crítico si el atacante está a 5 pies o menos de ella."
    },
    "petrified": {
      "name": "Petrificado",
      "desc": "Una criatura petrificada se transforma, junto con los objetos no mágicos que lleve puestos o cargue, en una sustancia sólida inanimada (normalmente piedra). Su peso se multiplica por diez y deja de envejecer. Está incapacitada, no puede moverse ni hablar y no percibe su entorno. Las tiradas de ataque contra ella tienen ventaja. Falla automáticamente las salvaciones de Fuerza y Destreza. Tiene resistencia a todo el daño y es inmune al veneno y la enfermedad."
    },
    "poisoned": {
      "name": "Envenenado",
      "desc": "Una criatura envenenada tiene desventaja en las tiradas de ataque y en las pruebas de característica."
    },
    "prone": {
      "name": "Derribado",
      "desc": "La única opción de movimiento de una criatura derribada es arrastrarse, a menos que se ponga en pie y termine así el estado. Tiene desventaja en las tiradas de ataque. Las tiradas de ataque contra la criatura tienen ventaja si el atacante está a 5 pies o menos de ella; si no, tienen desventaja."
    },
    "restrained": {
      "name": "Apresado",
      "desc": "La velocidad de una criatura apresada pasa a ser 0 y no puede beneficiarse de ningún bonificador a la velocidad. Las tiradas de ataque contra la criatura tienen ventaja y las tiradas de ataque de la criatura tienen desventaja. La criatura tiene desventaja en las tiradas de salvación de Destreza."
    },
    "stunned": {
      "name": "Aturdido",
      "desc": "Una criatura aturdida está incapacitada, no puede moverse y solo puede hablar entrecortadamente. Falla automáticamente las tiradas de salvación de Fuerza y Destreza. Las tiradas de ataque contra la criatura tienen ventaja."
    },
    "unconscious": {
      "name": "Inconsciente",
      "desc": "Una criatura inconsciente está incapacitada, no puede moverse ni hablar y no percibe su entorno. Suelta lo que esté sujetando y cae derribada. Falla automáticamente las salvaciones de Fuerza y Destreza. Las tiradas de ataque contra ella tienen ventaja. Cualquier ataque que la impacte es un golpe crítico si el atacante está a 5 pies o menos de ella."
    }
  },

  "weapon-properties": {
    "ammunition": {
      "name": "Munición",
      "desc": "Puedes usar un arma con esta propiedad para hacer un ataque a distancia solo si tienes munición. Cada ataque gasta una pieza; al final del combate recuperas la mitad de la munición gastada buscándola durante un minuto."
    },
    "finesse": {
      "name": "Sutil",
      "desc": "Al atacar con esta arma, eliges usar tu modificador de Fuerza o de Destreza tanto para la tirada de ataque como para la de daño (el mismo para ambas)."
    },
    "heavy": {
      "name": "Pesada",
      "desc": "Las criaturas Pequeñas tienen desventaja en las tiradas de ataque con armas pesadas."
    },
    "light": {
      "name": "Ligera",
      "desc": "Un arma ligera es pequeña y fácil de manejar, ideal para combatir con dos armas."
    },
    "loading": {
      "name": "Recarga",
      "desc": "Debido al tiempo de recarga, solo puedes disparar un proyectil por acción, acción adicional o reacción, aunque normalmente pudieras hacer más de un ataque."
    },
    "monk": {
      "name": "Monje",
      "desc": "Arma de monje: puede usarse con los rasgos de artes marciales."
    },
    "reach": {
      "name": "Alcance",
      "desc": "Esta arma añade 5 pies a tu alcance cuando atacas con ella."
    },
    "special": {
      "name": "Especial",
      "desc": "Un arma con esta propiedad tiene reglas inusuales; consulta su descripción."
    },
    "thrown": {
      "name": "Arrojadiza",
      "desc": "Puedes lanzar el arma para hacer un ataque a distancia, usando el mismo modificador de característica que usarías en cuerpo a cuerpo."
    },
    "two-handed": {
      "name": "A dos manos",
      "desc": "Esta arma requiere las dos manos cuando atacas con ella."
    },
    "versatile": {
      "name": "Versátil",
      "desc": "Puede usarse con una o dos manos. El valor de daño entre paréntesis se aplica al empuñarla a dos manos."
    }
  },

